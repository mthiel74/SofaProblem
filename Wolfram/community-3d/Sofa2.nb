    {
     PaneBox[
      StyleBox["\<\"Figure 1. Optimised sofa area A(w) as a function of arm-2 \
width, with the dashed linear fit and the Gerver bound for reference. A(w) is \
monotonically increasing and remarkably close to linear over w \[Element] \
[0.4, 1]; A(0) is 0 by geometry but the linear fit extrapolated to w = 0 \
lands well above 0, so the asymptotic shape near w = 0 is sub-linear.\"\>",
       StripOnInput->False,
       FontFamily->"Helvetica",
       FontSize->10,
       FontSlant->Italic],
      Alignment->Center,
      ImageSize->680]}
