    {
     PaneBox[
      StyleBox["\<\"Figure 4. The optimised S-corridor sofa, area 1.013. \
Strikingly, the shape collapses to an almost-perfectly-round disc of diameter \
\[TildeTilde] 1.3 (the disc inscribed in both bends simultaneously). Two \
consecutive 90\[Degree] turns drop the maximum from Gerver's 2.22 to barely \
above the unit disc \[Pi](0.6)\.b2 \[TildeTilde] 1.13.\"\>",
       StripOnInput->False,
       FontFamily->"Helvetica",
       FontSize->10,
       FontSlant->Italic],
      Alignment->Center,
      ImageSize->680]}
