 RowBox[{
  RowBox[{"regs", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"TransformedRegion", "[", 
      RowBox[{
       RowBox[{"TransformedRegion", "[", 
        RowBox[{"reg", ",", 
         RowBox[{"TranslationTransform", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "1.225"}], 
             RowBox[{"Sign", "[", 
              RowBox[{"Cos", "[", 
               RowBox[{"2", "alpha"}], "]"}], "]"}], 
