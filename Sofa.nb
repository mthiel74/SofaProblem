Cell[BoxData[
 RowBox[{
  RowBox[{"regs", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"TransformedRegion", "[", 
      RowBox[{
       RowBox[{"TransformedRegion", "[", 
        RowBox[{"reg", ",", 
         RowBox[{"TranslationTransform", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "1.04"}], 
             RowBox[{"Sign", "[", 
              RowBox[{"Cos", "[", 
               RowBox[{"2", "alpha"}], "]"}], "]"}], 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"Cos", "[", 
                RowBox[{"2", "alpha"}], "]"}], "]"}], "^", "1.1"}]}], ",", 
            RowBox[{"1", 
             RowBox[{"Sign", "[", 
