                RowBox[{"2", "alpha"}], "]"}], "]"}], "^", "1.1"}]}]}], "}"}],
           "]"}]}], "]"}], ",", 
       RowBox[{"RotationTransform", "[", 
        RowBox[{
         RowBox[{"-", "alpha"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], "]"}], ",", 
