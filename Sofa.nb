Cell[BoxData["NMaximize"], "Input",
 CellChangeTimes->{{3.7281709671363373`*^9, 
  3.7281709706528883`*^9}},ExpressionUUID->"edf29520-7e30-4313-b770-\
aa503999d6b3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"results", "=", 
   RowBox[{"{", "}"}]}], ";", 
  RowBox[{"Monitor", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"regs", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"TransformedRegion", "[", 
            RowBox[{
             RowBox[{"TransformedRegion", "[", 
              RowBox[{"reg", ",", 
               RowBox[{"TranslationTransform", "[", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"-", "amp"}], " ", 
                   RowBox[{"Sign", "[", 
                    RowBox[{"Cos", "[", 
                    RowBox[{"2", "alpha"}], "]"}], "]"}], 
                   RowBox[{
                    RowBox[{"Abs", "[", 
                    RowBox[{"Cos", "[", 
                    RowBox[{"2", "alpha"}], "]"}], "]"}], "^", "exp1"}]}], 
                  ",", 
                  RowBox[{"amp", " ", 
                   RowBox[{"Sign", "[", 
                    RowBox[{"Cos", "[", 
                    RowBox[{"2", "alpha"}], "]"}], "]"}], 
                   RowBox[{
                    RowBox[{"Abs", "[", 
                    RowBox[{"Cos", "[", 
                    RowBox[{"2", "alpha"}], "]"}], "]"}], "^", "exp1"}]}]}], 
                 "}"}], "]"}]}], "]"}], ",", 
             RowBox[{"RotationTransform", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Sign", "[", 
                 RowBox[{
                  RowBox[{"-", "alpha"}], "+", 
                  RowBox[{"Pi", "/", "4."}]}], "]"}], 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"Abs", "[", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "alpha"}], "+", 
                    RowBox[{"Pi", "/", "4."}]}], ")"}], "]"}], "*", 
                   RowBox[{"4", "/", "Pi"}]}], ")"}], "^", "exp2"}], "*", 
                RowBox[{"Pi", "/", "4."}]}], ",", 
               RowBox[{"{", 
                RowBox[{"0", ",", 
                 RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"alpha", ",", "0", ",", 
             RowBox[{"Pi", "/", "2"}], ",", "0.015"}], "}"}]}], "]"}]}], ";", 
        
        RowBox[{"AppendTo", "[", 
         RowBox[{"results", ",", 
          RowBox[{"{", 
           RowBox[{"amp", ",", "exp1", ",", "exp2", ",", 
            RowBox[{"Area", "[", 
             RowBox[{"Fold", "[", 
              RowBox[{"RegionIntersection", ",", "regs"}], "]"}], "]"}]}], 
           "}"}]}], "]"}], ";", 
        RowBox[{"Export", "[", 
         RowBox[{"\"\<~/Desktop/results.mx\>\"", ",", "results"}], "]"}]}], 
