Cell[BoxData[
 RowBox[{
  RowBox[{"regs", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"TransformedRegion", "[", 
      RowBox[{
       RowBox[{"TransformedRegion", "[", 
        RowBox[{"reg", ",", 
         RowBox[{"TranslationTransform", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "1.2"}], 
             RowBox[{"Sign", "[", 
              RowBox[{"Cos", "[", 
               RowBox[{"2", "alpha"}], "]"}], "]"}], 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"Cos", "[", 
                RowBox[{"2", "alpha"}], "]"}], "]"}], "^", "0.7"}]}], ",", 
            RowBox[{"1.2", 
             RowBox[{"Sign", "[", 
              RowBox[{"Cos", "[", 
               RowBox[{"2", "alpha"}], "]"}], "]"}], 
             RowBox[{
              RowBox[{"Abs", "[", 
               RowBox[{"Cos", "[", 
                RowBox[{"2", "alpha"}], "]"}], "]"}], "^", "0.7"}]}]}], "}"}],
           "]"}]}], "]"}], ",", 
       RowBox[{"RotationTransform", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Sign", "[", 
           RowBox[{
            RowBox[{"-", "alpha"}], "+", 
            RowBox[{"Pi", "/", "4."}]}], "]"}], 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"-", "alpha"}], "+", 
                RowBox[{"Pi", "/", "4."}]}], ")"}], "]"}], "*", 
             RowBox[{"4", "/", "Pi"}]}], ")"}], "^", "0.53"}], "*", 
          RowBox[{"Pi", "/", "4."}]}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", 
           RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"alpha", ",", "0", ",", 
       RowBox[{"Pi", "/", "2"}], ",", "0.015"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
